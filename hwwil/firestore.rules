rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── transfers: عملاء يكتبون فقط، أدمن يقرأ ويعدل ──
    match /transfers/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── cards: عملاء يكتبون فقط، أدمن يقرأ ويعدل ──
    match /cards/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── stock: أدمن فقط ──
    match /stock/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── banks: الكل يقرأ، أدمن يكتب ──
    match /banks/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── games: الكل يقرأ، أدمن يكتب ──
    match /games/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}